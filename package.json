{
  "name": "openclaw-pawpad",
  "version": "0.2.1",
  "description": "Per-session task list and notes for OpenClaw agents",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "MIT",
  "engines": {
    "node": ">=22.14.0"
  },
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc",
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "prepack": "npm run clean && npm run build"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "tasks",
    "scratchpad",
    "context-compaction"
  ],
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "files": [
    "dist/",
    "openclaw.plugin.json",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "dependencies": {
    "@sinclair/typebox": "0.34.48"
  },
  "devDependencies": {
    "@mariozechner/pi-agent-core": "^0.73.0",
    "openclaw": "^2026.5.4",
    "typescript": "^6.0.3",
    "vitest": "^3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/whtsky/openclaw-pawpad.git"
  }
}
